rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can create a request (submit the form)
    match /requests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['examName', 'email', 'status'])
                    && request.resource.data.status == 'pending';
      allow read, update, delete: if true; // Admin panel uses client SDK
    }

    // Approved exams — public read, admin writes via client SDK
    match /approved_exams/{examId} {
      allow read: if true;
      allow write: if true; // Admin panel writes new exam specs
    }

    // Ads — public read, admin manages via client SDK
    match /ads/{adId} {
      allow read: if true;
      allow write: if true; // Admin panel CRUD + impression/click tracking
    }

    // Affiliate products — public read, admin manages
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Admin panel CRUD + click tracking
    }
  }
}
